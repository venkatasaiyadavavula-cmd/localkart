# NEXT_PUBLIC_* variables are inlined into the client bundle at `npm run build` time.
# They are NOT read from the server at runtime. Changing them requires a frontend rebuild.
# Production deploy (.github/workflows/deploy.yml) exports NEXT_PUBLIC_RAZORPAY_KEY_ID from backend/.env before build.
NEXT_PUBLIC_API_URL=https://api.localkart.store/api/v1
NEXT_PUBLIC_APP_URL=https://localkart.store
# Razorpay checkout key (public). Must match backend RAZORPAY_KEY_ID. Set on server via backend/.env; deploy syncs it at build.
NEXT_PUBLIC_RAZORPAY_KEY_ID=
